# Environment variables for Project Management MVP
# Copy this to .env and fill in values before running the app

# OpenRouter API key for AI calls
OPENROUTER_API_KEY=

# Google OAuth credentials (from Google Cloud Console)
# Register http://localhost:8000/api/auth/google/callback as an authorised redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public base URL used as the OAuth redirect URI
# Local development: http://localhost:8000
APP_BASE_URL=http://localhost:8000

# Secret key for signing JWTs — generate with: openssl rand -hex 32
JWT_SECRET=

# App environment: development | production
# The /api/auth/dev-login bypass is disabled when set to "production"
APP_ENV=development
